# Required model configuration
MILKY_FROG_API_KEY=your-api-key
MILKY_FROG_MODEL=deepseek-v4-flash

# Optional OpenAI-compatible endpoint
MILKY_FROG_BASE_URL=https://api.deepseek.com

# Optional state directory (default: ~/.milky-frog)
# MILKY_FROG_HOME=~/.milky-frog

# Optional retry settings for model calls
# MILKY_FROG_MAX_RETRIES=3
# MILKY_FROG_RETRY_BASE_DELAY=1.0

# Langfuse observability (optional)
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_FLUSH_TIMEOUT=10.0
